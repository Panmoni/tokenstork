# tokenstork pnpm config
# Strict peer deps catches missing peer dependencies at install time
# rather than at runtime — preferred for a SvelteKit app where peer
# mismatches surface as cryptic Vite errors.
strict-peer-dependencies=true

# Don't silently install peer deps — force them to be declared explicitly
# in package.json. Mirrors npm 7+ behavior we're used to.
auto-install-peers=false

# Native modules require explicit allowlist under pnpm 10+; the source
# of truth is package.json's pnpm.onlyBuiltDependencies, so this file
# stays minimal.

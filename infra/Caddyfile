# tokenstork.com — serves behind Cloudflare proxy (orange cloud).
#
# TLS model:
# - Cloudflare SSL/TLS mode: Full (strict)
# - This origin presents a Cloudflare Origin Certificate (15-year validity,
#   issued from the Cloudflare Origin CA that CF implicitly trusts). No ACME
#   means renewal never fights the proxy.
# - www → apex redirect runs at the Cloudflare edge (Page Rule / Redirect
#   Rule), not here — Caddy only handles the apex.
# - Logs go to journald (systemd). Use `journalctl -u caddy` to read them.
#
# If you're deploying WITHOUT Cloudflare (pure public-IP origin), remove the
# `tls /etc/caddy/tls/...` line and replace the site address line with e.g.
# `tokenstork.com, www.tokenstork.com {` — Caddy will auto-provision from
# Let's Encrypt.

tokenstork.com {
	tls /etc/caddy/tls/tokenstork.com.crt /etc/caddy/tls/tokenstork.com.key

	# Access log to stdout → captured by systemd-journald (single-server
	# deploy). Filter noisy paths that'd fill the journal without value.
	log {
		output stdout
		format json
	}

	encode zstd gzip

	@immutable path /_app/immutable/*
	header @immutable Cache-Control "public, max-age=31536000, immutable"

	@assets path *.ico *.png *.webmanifest *.svg *.txt
	header @assets Cache-Control "public, max-age=86400"

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Content-Security-Policy "default-src 'self'; script-src 'self' https://beamanalytics.b-cdn.net; style-src 'self' 'unsafe-inline'; img-src 'self' https: data:; font-src 'self' data:; connect-src 'self' https://beamanalytics.b-cdn.net; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests"
	}

	reverse_proxy 127.0.0.1:3000
}

# tokenstork.com — serves behind Cloudflare proxy (orange cloud).
#
# TLS model:
# - Cloudflare SSL/TLS mode: Full (strict)
# - This origin presents a Cloudflare Origin Certificate (15-year validity,
#   issued from the Cloudflare Origin CA that CF implicitly trusts). No ACME
#   means renewal never fights the proxy.
# - www → apex redirect runs at the Cloudflare edge (Page Rule / Redirect
#   Rule), not here — Caddy only handles the apex.
# - Logs go to journald (systemd). Use `journalctl -u caddy` to read them.
#
# If you're deploying WITHOUT Cloudflare (pure public-IP origin), remove the
# `tls /etc/caddy/tls/...` line and replace the site address line with e.g.
# `tokenstork.com, www.tokenstork.com {` — Caddy will auto-provision from
# Let's Encrypt.

tokenstork.com {
	tls /etc/caddy/tls/tokenstork.com.crt /etc/caddy/tls/tokenstork.com.key

	# Access log to stdout → captured by systemd-journald (single-server
	# deploy). Filter noisy paths that'd fill the journal without value.
	log {
		output stdout
		format json
	}

	encode zstd gzip

	@immutable path /_app/immutable/*
	header @immutable Cache-Control "public, max-age=31536000, immutable"

	@assets path *.ico *.png *.webmanifest *.svg *.txt
	header @assets Cache-Control "public, max-age=86400"

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		# Content-Security-Policy lives in svelte.config.js (kit.csp,
		# mode: 'hash'). SvelteKit emits a `<meta http-equiv>` tag with
		# SHA-256 hashes of its own inline hydration script in every SSR
		# response. Setting a CSP header here too would intersect with
		# the meta CSP at the browser, and the header (lacking the build-
		# time hashes) would block every legitimate inline script. So we
		# deliberately don't ship one from Caddy. Static assets (PNGs,
		# fonts) don't need CSP protection.
	}

	# Upstream retry — smooths over the 1-3 second window during
	# `systemctl restart tokenstork.service` on deploys. Without this,
	# any request that lands between the SIGTERM and the new process's
	# :3000 bind gets a 502/connection-refused. With `lb_try_duration`,
	# Caddy keeps redialing the single upstream for up to 15 seconds at
	# 250 ms intervals before giving up. Under normal healthy traffic
	# this costs nothing; during a deploy it converts would-be 5xx into
	# a brief pause.
	#
	# `fail_duration` + `unhealthy` are no-ops on a single-upstream
	# setup (nothing to mark unhealthy) but the retry budget alone is
	# what matters here.
	reverse_proxy 127.0.0.1:3000 {
		lb_try_duration 15s
		lb_try_interval 250ms
	}
}

# tokenstork environment — single-box VPS deployment.
# Copy to .env.local (for Next.js) and/or .env (for systemd) and fill in.

# ---- Postgres (localhost) ----
DATABASE_URL=postgresql://tokenstork@127.0.0.1:5432/tokenstork

# ---- BCHN (localhost) ----
BCHN_RPC_URL=http://127.0.0.1:8332
BCHN_RPC_AUTH=tokenstork:CHANGE_ME_RANDOM_32_CHARS
BCHN_ZMQ_URL=tcp://127.0.0.1:28332

# ---- BlockBook (localhost) ----
BLOCKBOOK_URL=http://127.0.0.1:9130
BLOCKBOOK_MAX_RPS=10

# ---- Enrichment worker tuning (optional) ----
# ENRICH_BATCH=200

# ---- Verifier worker tuning (optional) ----
# VERIFY_SAMPLE=50

# ---- Existing app keys (already in use) ----
# CRYPTO_COMPARE_KEY=

# ---- Stork Sightings (Daily Briefing) ----
# LLM provider: DeepInfra (https://api.deepinfra.com/v1/openai)
# Auth: defaults to DEEPINFRA_API_KEY from ~/.zshrc if BRIEFING_LLM_API_KEY is unset
# BRIEFING_LLM_BASE_URL=https://api.deepinfra.com/v1/openai
# BRIEFING_LLM_API_KEY=
# BRIEFING_LLM_MODEL=zai-org/GLM-5.2
# BRIEFING_LLM_REVIEW_MODEL=deepseek-ai/DeepSeek-V4-Pro
# BRIEFING_WINDOW_HOURS=24
# BRIEFING_OUTPUT_DIR=briefings
# BRIEFING_PUBLIC_URL=https://tokenstork.com
# BRIEFING_SUBSTACK_URL=https://tokenstork.substack.com

# ---- Email delivery (Resend) ----
# RESEND_API_KEY=
# EMAIL_FROM=onboarding@resend.dev
# EMAIL_TO=resend.scallop000@passmail.net

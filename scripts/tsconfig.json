{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmit": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": false,
    "jsx": "preserve",
    "types": ["node"]
  },
  "include": ["./**/*.ts", "../lib/**/*.ts"],
  "exclude": ["../node_modules", "../.next"]
}

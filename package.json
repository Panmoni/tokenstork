{
  "name": "tokenstorkapp",
  "version": "0.0.2 (beta)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "db:init": "psql \"$DATABASE_URL\" -f db/schema.sql",
    "sync:backfill": "tsx scripts/backfill-from-bchn.ts",
    "sync:tail": "tsx scripts/tail-from-bchn.ts",
    "sync:enrich": "tsx scripts/enrich-from-blockbook.ts",
    "sync:verify": "tsx scripts/verify-current-state.ts",
    "typecheck": "tsc --noEmit --project scripts/tsconfig.json"
  },
  "dependencies": {
    "@types/pg": "^8.20.0",
    "autoprefixer": "^10.5.0",
    "pg": "^8.20.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "better-sqlite3": "^12.9.0",
    "electrum-cash": "^3.2.0",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "zeromq": "^6.5.0"
  }
}

    "@walletconnect/sign-client": "^2.23.9",
    "autoprefixer": "^10.5.0",
    "bits-ui": "^2.18.0",
    "clsx": "^2.1.1",
    "pg": "^8.20.0",
    "postcss": "^8.5.10",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
